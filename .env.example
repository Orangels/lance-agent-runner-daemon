# PostgreSQL database used by the daemon runtime.
# This database stores workspaces, runs, messages, artifacts metadata, logs metadata,
# idempotency records, snapshots, and feedback after the PostgreSQL migration.
CLAUDE_RUNNER_DATABASE_URL=postgres://user:password@localhost:5432/lance_agent_daemon

# PostgreSQL database used by automated daemon tests.
# This database must be safe for tests to migrate, truncate, and recreate.
# Do not point this at a business integration or production database.
CLAUDE_RUNNER_TEST_PG_URL=postgres://user:password@localhost:5432/lance_agent_daemon_test
