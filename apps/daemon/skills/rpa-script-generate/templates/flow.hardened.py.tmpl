def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--config", default=default_config_path())
    parser.add_argument("--params", default="run.params.json")
    parser.add_argument("--execution-dir", default=".")
    parser.add_argument("--mode", choices=["verify", "dry-run", "run"], default="verify")
    parser.add_argument("--dry-run", action="store_true")
    headless_group = parser.add_mutually_exclusive_group()
    headless_group.add_argument("--headless", action="store_true")
    headless_group.add_argument("--headed", action="store_true")
    args = parser.parse_args()

    execution_dir = str(Path(args.execution_dir).resolve())
    config = normalize_runtime_config(load_json(args.config), execution_dir)
    params = load_json(args.params) if Path(args.params).exists() else {}
    dry_run = args.dry_run or is_dry_run(args.mode)
    headless = resolve_headless(config, args.mode, args.headless, args.headed)

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=headless, slow_mo=config.get("browser", {}).get("slow_mo_ms", 0))
        context = browser.new_context(storage_state=config.get("storage_state") or None, accept_downloads=True)
        page = context.new_page()
        page.set_default_timeout(config.get("default_timeout_ms", 15000))
        try:
            run_flow(page, config, params, args.mode, dry_run)
        except Exception as exc:
            audit(config, {"status": "failed", "error": str(exc), "mode": args.mode, "dry_run": dry_run})
            raise
        finally:
            context.close()
            browser.close()


if __name__ == "__main__":
    main()
