import argparse
import json
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

from playwright.sync_api import Page, sync_playwright, expect


def load_json(path: str) -> dict[str, Any]:
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def ensure_dir(path: str) -> None:
    Path(path).mkdir(parents=True, exist_ok=True)


def is_dry_run(mode: str) -> bool:
    return mode in {"verify", "dry-run"}


def default_config_path() -> str:
    return str(Path(__file__).with_name("config.example.json"))


def resolve_runtime_path(execution_dir: str, configured_path: str) -> str:
    path = Path(configured_path)
    if path.is_absolute():
        return str(path)
    return str(Path(execution_dir) / path)


def normalize_runtime_config(config: dict[str, Any], execution_dir: str) -> dict[str, Any]:
    audit_config = config.setdefault("audit", {})
    audit_config["jsonl_path"] = resolve_runtime_path(
        execution_dir,
        audit_config.get("jsonl_path", "runtime/audit.jsonl"),
    )
    audit_config["screenshots_dir"] = resolve_runtime_path(
        execution_dir,
        audit_config.get("screenshots_dir", "runtime/screenshots"),
    )
    audit_config["trace_dir"] = resolve_runtime_path(
        execution_dir,
        audit_config.get("trace_dir", "runtime/trace"),
    )
    downloads_config = config.setdefault("downloads", {})
    downloads_config["dir"] = resolve_runtime_path(execution_dir, downloads_config.get("dir", "runtime/downloads"))
    return config


def resolve_headless(config: dict[str, Any], mode: str, force_headless: bool, force_headed: bool) -> bool:
    if force_headless:
        return True
    if force_headed:
        return False
    return bool(config.get("browser", {}).get("headless", mode == "run"))


def audit(config: dict[str, Any], event: dict[str, Any]) -> None:
    audit_path = Path(config["audit"]["jsonl_path"])
    ensure_dir(str(audit_path.parent))
    event.setdefault("ts", datetime.now(timezone.utc).isoformat())
    with audit_path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, ensure_ascii=False) + "\n")


def screenshot(page: Page, config: dict[str, Any], step_id: str) -> str:
    screenshots_dir = config["audit"]["screenshots_dir"]
    ensure_dir(screenshots_dir)
    path = Path(screenshots_dir) / f"{step_id}.png"
    page.screenshot(path=str(path), full_page=True)
    return str(path)


def download_artifact_path(config: dict[str, Any], relative_name: str) -> Path:
    relative = Path(relative_name)
    if relative.is_absolute() or ".." in relative.parts:
        raise ValueError("download artifact path must stay under downloads dir")
    path = Path(config["downloads"]["dir"]) / relative
    ensure_dir(str(path.parent))
    return path


