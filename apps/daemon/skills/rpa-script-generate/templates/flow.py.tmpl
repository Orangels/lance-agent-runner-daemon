import argparse
import json
from pathlib import Path

from playwright.sync_api import sync_playwright, expect


def load_json(path: str) -> dict:
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def resolve_param(value: str, params: dict, context: dict) -> str:
    if isinstance(value, str) and value.startswith("${") and value.endswith("}"):
        key = value[2:-1]
        if key in params:
            return params[key]
        if key in context:
            return context[key]
    return value


def default_config_path() -> str:
    return str(Path(__file__).with_name("config.example.json"))


def resolve_headless(config: dict, mode: str, force_headless: bool, force_headed: bool) -> bool:
    if force_headless:
        return True
    if force_headed:
        return False
    return bool(config.get("browser", {}).get("headless", mode == "run"))


def is_dry_run(mode: str) -> bool:
    return mode in {"verify", "dry-run"}


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--config", default=default_config_path())
    parser.add_argument("--params", default="run.params.json")
    parser.add_argument("--execution-dir", default=".")
    parser.add_argument("--mode", choices=["verify", "dry-run", "run"], default="verify")
    parser.add_argument("--dry-run", action="store_true")
    headless_group = parser.add_mutually_exclusive_group()
    headless_group.add_argument("--headless", action="store_true")
    headless_group.add_argument("--headed", action="store_true")
    args = parser.parse_args()

    config = load_json(args.config)
    params = load_json(args.params) if Path(args.params).exists() else {}
    dry_run = args.dry_run or is_dry_run(args.mode)
    headless = resolve_headless(config, args.mode, args.headless, args.headed)

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=headless, slow_mo=config.get("browser", {}).get("slow_mo_ms", 0))
        context = browser.new_context(storage_state=config.get("storage_state") or None, accept_downloads=True)
        page = context.new_page()
        page.set_default_timeout(config.get("default_timeout_ms", 15000))

        page.goto(config["base_url"])
        expect(page.locator("body")).to_be_visible()

        # Add generated flow steps here from flow.dsl.json.
        # Use dry_run to skip or pause irreversible write operations.

        context.close()
        browser.close()


if __name__ == "__main__":
    main()
